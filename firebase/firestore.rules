rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ─────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isGlobalAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isCommunityAdmin(communityId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/community_members/$(communityId + '_' + request.auth.uid)) &&
        get(/databases/$(database)/documents/community_members/$(communityId + '_' + request.auth.uid)).data.role == 'admin';
    }

    function isCommunityMember(communityId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/community_members/$(communityId + '_' + request.auth.uid)) &&
        get(/databases/$(database)/documents/community_members/$(communityId + '_' + request.auth.uid)).data.status == 'approved';
    }

    function validUserData() {
      return request.resource.data.keys().hasAll(['displayName', 'email']) &&
        request.resource.data.displayName is string &&
        request.resource.data.email is string;
    }

    // ─── Users ────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && validUserData();
      allow update: if isOwner(userId) || isGlobalAdmin();
      allow delete: if isGlobalAdmin();
    }

    // ─── Communities ──────────────────────────────────────────────────────────

    match /communities/{communityId} {
      allow read: if isAuthenticated();
      allow create: if isGlobalAdmin();
      allow update: if isGlobalAdmin() || isCommunityAdmin(communityId);
      allow delete: if isGlobalAdmin();
    }

    // ─── Community Members ────────────────────────────────────────────────────

    match /community_members/{memberId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isGlobalAdmin() || isCommunityAdmin(resource.data.communityId);
      allow delete: if isGlobalAdmin() || isCommunityAdmin(resource.data.communityId) ||
        (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // ─── Services ─────────────────────────────────────────────────────────────

    match /services/{serviceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        isGlobalAdmin() ||
        isCommunityAdmin(request.resource.data.communityId) ||
        isCommunityMember(request.resource.data.communityId)
      );
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isCommunityAdmin(resource.data.communityId) ||
        isGlobalAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isCommunityAdmin(resource.data.communityId) ||
        isGlobalAdmin()
      );
    }

    // ─── Companies ────────────────────────────────────────────────────────────

    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        isGlobalAdmin() ||
        isCommunityAdmin(request.resource.data.communityId) ||
        isCommunityMember(request.resource.data.communityId)
      );
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isCommunityAdmin(resource.data.communityId) ||
        isGlobalAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isCommunityAdmin(resource.data.communityId) ||
        isGlobalAdmin()
      );
    }

    // ─── Reviews ─────────────────────────────────────────────────────────────

    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isGlobalAdmin()
      );
    }

    // ─── Favorites ────────────────────────────────────────────────────────────

    match /favorites/{favoriteId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId);
    }

    // ─── Messages ─────────────────────────────────────────────────────────────

    match /messages/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/messages/$(chatId)).data.participants;
        allow create: if isAuthenticated() &&
          request.resource.data.senderId == request.auth.uid &&
          request.auth.uid in get(/databases/$(database)/documents/messages/$(chatId)).data.participants;
        allow update: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/messages/$(chatId)).data.participants;
      }
    }

    // ─── Notifications ────────────────────────────────────────────────────────

    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isGlobalAdmin() || isCommunityAdmin(resource.data.communityId);
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId) || isGlobalAdmin();
    }

    // ─── Categories ───────────────────────────────────────────────────────────

    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isGlobalAdmin() || isCommunityAdmin(resource.data.communityId);
    }
  }
}
