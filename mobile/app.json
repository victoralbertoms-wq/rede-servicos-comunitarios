{
  "expo": {
    "name": "Rede de Serviços",
    "slug": "rede-servicos-comunitarios",
    "owner": "fraternidadehumana",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4f46e5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.redeservicos.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Para enviar fotos do seu perfil e serviços.",
        "NSPhotoLibraryUsageDescription": "Para selecionar imagens da galeria."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4f46e5"
      },
      "package": "com.redeservicos.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir acesso às fotos para enviar imagens.",
          "cameraPermission": "Permitir acesso à câmera para tirar fotos."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "fdef6951-adda-4c6b-abdc-41b60e93d8b9"
      }
    }
  }
}
